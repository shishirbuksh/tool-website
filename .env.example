# ============================================================
# StoryBrain AI — Production Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Application
PROJECT_NAME="StoryBrain AI"
SECRET_KEY=change-me-to-a-random-secret-key

# Server binding
HOST=0.0.0.0
PORT=8090

# Gunicorn workers (0 = auto: cores + 1)
WORKERS=0
LOG_LEVEL=info
TIMEOUT=120
KEEP_ALIVE=5

# Redis (optional — app falls back to in-memory cache if unavailable)
REDIS_URL=

# Security — comma-separated, no spaces
# Example: ALLOWED_HOSTS=storybrainai.com,www.storybrainai.com
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=
