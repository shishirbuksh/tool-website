# ============================================================
# StoryBrain AI — Production Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Application
PROJECT_NAME="StoryBrain AI"
SITE_URL=https://www.storybrainai.com

# Server binding
HOST=0.0.0.0
PORT=8090

# Gunicorn workers (0 = auto: cores + 1)
WORKERS=0
LOG_LEVEL=info
TIMEOUT=120
KEEP_ALIVE=5

# Redis (optional — app falls back to in-memory cache if unavailable)
REDIS_URL=

# Security — comma-separated, no spaces
# IMPORTANT: Must include your actual domain + VPS IP, or requests will be rejected.
# Example: ALLOWED_HOSTS=storybrainai.com,*.storybrainai.com,your-vps-ip
ALLOWED_HOSTS=localhost,127.0.0.1,*.storybrainai.com,storybrainai.com,testserver
CORS_ORIGINS=
