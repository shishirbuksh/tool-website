  "description": "StoryBrain AI — 70+ Free Online Tools",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build:css": "cross-env NODE_ENV=production postcss src/input.css -o static/css/app.css --minify",
    "build:js": "cross-env NODE_ENV=production node scripts/build.js",
    "build:js:dev": "cross-env NODE_ENV=development node scripts/build.js",
