  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.2",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "sharp": "^0.35.3",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.1",
