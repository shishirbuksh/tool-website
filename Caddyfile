# StoryBrain AI — Caddy reverse proxy with automatic HTTPS
# Replace with your actual domain before deploying

storybrainai.com, www.storybrainai.com {
    # Automatic HTTPS via Let's Encrypt (Caddy handles this)

    encode gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # Proxy to FastAPI backend
    reverse_proxy app:8090 {
        # Pass real IP to backend
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Cache static assets
    handle_path /static/* {
        root * /app/static
        file_server {
            precompressed br gzip
        }
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Handle Service Worker (must NOT be cached)
    handle_path /sw.js {
        reverse_proxy app:8090 {
            header_up Host {host}
        }
    }
}

# Local dev shortcut
localhost:8080 {
    reverse_proxy app:8090
}
