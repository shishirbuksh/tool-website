# StoryBrain AI — Caddy reverse proxy with automatic HTTPS
# Override env vars for custom deployment:
#   CADDY_DOMAIN, CADDY_PROXY_UPSTREAM, CADDY_STATIC_ROOT

{$CADDY_DOMAIN:storybrainai.com, www.storybrainai.com} {
    @nonwww {
        not host www.storybrainai.com
    }
    redir @nonwww https://www.storybrainai.com{uri} 301

    encode zstd br gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # Proxy to FastAPI backend
    reverse_proxy {$CADDY_PROXY_UPSTREAM:app:8090} {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Cache static assets
    handle_path /static/* {
        root * {$CADDY_STATIC_ROOT:/app/static}
        file_server {
            precompressed br gzip
        }
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Handle Service Worker (must NOT be cached)
    handle_path /sw.js {
        reverse_proxy {$CADDY_PROXY_UPSTREAM:app:8090} {
            header_up Host {host}
        }
    }
}
